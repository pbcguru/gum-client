{
    "name": "pbc/gum-client",
    "description": "Client library for PBC Global User Management (GUM) service",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Pbc\\GumClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pbc\\GumClient\\GumClientServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0",
        "firebase/php-jwt": "^6.10|^7.0"
    }
}
